<?xml version="1.0"?>
<robot name="cartesian_robot_2d">

  <!--
  <link name="frame1">
    <visual>
      <geometry>
        <box size="1.1 0.1 0.1"/>
      </geometry>
      <origin xyz="0 -0.05 0" rpy="0 0 0"/>
      <material name="grey">
        <color rgba="0.5 0.5 0.5 1"/>
      </material>
    </visual>
  </link>
-->
  <link name="frame2">
    <visual>
      <geometry>
        <box size="1.1 0.1 0.1"/>
      </geometry>
      <origin xyz="0 1.05 0" rpy="0 0 0"/>
      <material name="grey">
        <color rgba="0.5 0.5 0.5 1"/>
      </material>
    </visual>
  </link>

  <link name="link_x">
    <visual>
      <geometry>
        <box size="0.1 1.0 0.1"/>
      </geometry>
      <origin xyz="0 0.5 0" rpy="0 0 0"/>
      <material name="red">
        <color rgba="1 0 0 1"/>
      </material>
    </visual>
  </link>

  <link name="link_y">
    <visual>
      <geometry>
        <box size="0.15 0.15 0.15"/>
      </geometry>
      <origin xyz="0.0 0.5 0" rpy="0 0 0"/>
      <material name="green">
        <color rgba="0 1 0 1"/>
      </material>
    </visual>
  </link>

  <link name="link_z">
    <visual>
      <geometry>
        <cylinder radius="0.04" length="0.3"/>
      </geometry>
      <origin xyz="0.0 0.5 0" rpy="0 0 0"/>
      <material name="blue">
        <color rgba="0 0 1 1"/>
      </material>
    </visual>
  </link>

  <joint name="joint_x" type="prismatic">
    <parent link="frame2"/>
    <child link="link_x"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="-0.5" upper="0.5" effort="100" velocity="10"/>
  </joint>

  <joint name="joint_y" type="prismatic">
    <parent link="link_x"/>
    <child link="link_y"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-0.45" upper="0.45" effort="100" velocity="10"/>
  </joint>

  <joint name="joint_z" type="prismatic">
    <parent link="link_y"/>
    <child link="link_z"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-0.1" upper="0.0" effort="100" velocity="10"/>
  </joint>

</robot>