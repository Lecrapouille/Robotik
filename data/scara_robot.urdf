<?xml version="1.0"?>
<robot name="scara_robot">

  <!-- Base Link -->
  <link name="base_link">
    <visual>
      <geometry>
        <box size="0.12 0.12 0.12"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <material name="gray">
        <color rgba="0.5 0.5 0.5 1"/>
      </material>
    </visual>
  </link>

  <!-- Link 1 (First arm segment) -->
  <link name="link1">
    <visual>
      <geometry>
        <box size="0.350 0.09 0.025"/>
      </geometry>
      <origin xyz="0.175 0 0" rpy="0 0 0"/>
      <material name="blue">
        <color rgba="0 0 1 1"/>
      </material>
    </visual>
  </link>

  <!-- Link 2 (Second arm segment) -->
  <link name="link2">
    <visual>
      <geometry>
        <box size="0.450 0.09 0.025"/>
      </geometry>
      <origin xyz="0.225 0 0" rpy="0 0 0"/>
      <material name="red">
        <color rgba="1 0 0 1"/>
      </material>
    </visual>
  </link>

  <!-- Link End Effector -->
  <link name="link_end_effector">
    <visual>
      <geometry>
        <cylinder radius="0.02" length="0.2"/>
      </geometry>
      <origin xyz="0 0 0.1" rpy="0 0 0"/>
      <material name="orange">
        <color rgba="1 0.5 0 1"/>
      </material>
    </visual>
  </link>

  <!-- Joint 1: Base to Link 1 (θ1) -->
  <joint name="joint1" type="revolute">
    <parent link="base_link"/>
    <child link="link1"/>
    <origin xyz="0 0 0.06" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14" upper="3.14" effort="10" velocity="1"/>
    <dynamics damping="0.1" friction="0.1"/>
  </joint>

  <!-- Joint 2: Link 1 to Link 2 (θ2) -->
  <joint name="joint2" type="revolute">
    <parent link="link1"/>
    <child link="link2"/>
    <origin xyz="0.35 0 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14" upper="3.14" effort="8" velocity="1"/>
    <dynamics damping="0.1" friction="0.1"/>
  </joint>

  <!-- End Effector: Link 2 to End Effector (d3 - Prismatic) -->
  <joint name="end_effector" type="prismatic">
    <parent link="link2"/>
    <child link="link_end_effector"/>
    <origin xyz="0.45 0 0" rpy="0 0 0"/>
    <axis xyz="0 0 -1"/>
    <limit lower="0.038" upper="0.16" effort="5" velocity="0.2"/>
    <dynamics damping="0.1" friction="0.1"/>
  </joint>

</robot>